---
/**
 * About Page
 *
 * Company introduction page with fully customizable content placeholders
 * All content has been extracted into the aboutData object for easy AI agent customization
 *
 * AI AGENTS: This page is designed to be customized by replacing the placeholder
 * values in the aboutData object below. Each placeholder is clearly marked with [YOUR_...]
 */

import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Layout from '~/layouts/PageLayout.astro';

// ========================================================================
// 🎯 ABOUT PAGE CONFIGURATION
// ========================================================================
//
// AI AGENTS & DEVELOPERS:
// All page content is centralized here. Replace the placeholders below with
// your company's actual information to customize this page.
//
// Each section is marked with clear comments explaining what content should go there.
//
// ========================================================================

const aboutData = {
  // ========================================================================
  // 1. PAGE METADATA
  // ========================================================================
  metadata: {
    title: '[YOUR_SITE_NAME]', // Page title shown in browser tab
  },

  // ========================================================================
  // 2. HERO SECTION
  // ========================================================================
  hero: {
    tagline: 'About [YOUR_SITE_NAME]', // Badge/tagline above the title

    // Main heading - can include HTML for styling
    title:
      'In the age of [YOUR_INNOVATION_FOCUS], <br /> <span class="text-accent dark:text-white highlight">[YOUR_VALUE_PROPOSITION]</span>',
    // Example: 'In the age of AI, <br /> <span class="text-accent dark:text-white highlight">Precision Beats Power</span>'

    // Subtitle/description - your company's core business description
    subtitle: '[YOUR_COMPANY_ONE_SENTENCE_PITCH]',
    // Example: '[Your Company] is a forward-thinking company specializing in [Your Core Business] and [Your Secondary Focus]. We help our clients achieve [Target Outcome] through innovation and expertise.'

    // Hero background image
    image: {
      src: 'https://images.unsplash.com/photo-1604871000636-074fa5117945?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Abstract business background',
    },
  },

  // ========================================================================
  // 3. CORE PHILOSOPHY (4 Grid Items - Top Section)
  // ========================================================================
  // Displayed as a 4-column grid below the hero section
  // Each item: title (short), description (very short), icon
  corePhilosophy: {
    title: '[YOUR_CORE_VALUES_TITLE]',
    // Example: 'Our Core Philosophy' or 'What Drives Us'
    subtitle: '[YOUR_CORE_VALUES_SUBTITLE]',
    // Example: 'Our core philosophy defines how we build for the future.'
    items: [
      { title: '[PHILOSOPHY_1_TITLE]', description: '[PHILOSOPHY_1_DESC]', icon: 'tabler:rocket' },
      { title: '[PHILOSOPHY_2_TITLE]', description: '[PHILOSOPHY_2_DESC]', icon: 'tabler:target' },
      { title: '[PHILOSOPHY_3_TITLE]', description: '[PHILOSOPHY_3_DESC]', icon: 'tabler:shield' },
      { title: '[PHILOSOPHY_4_TITLE]', description: '[PHILOSOPHY_4_DESC]', icon: 'tabler:trophy' },
    ],
  },

  // ========================================================================
  // 4. PHILOSOPHY DETAILS (Split Layout - Left: List, Right: Image)
  // ========================================================================
  // Displayed as a 2-column section with an image
  // Each item: title, description (1-2 sentences), icon
  philosophyDetails: {
    title: '[YOUR_COMPANY_PHILOSOPHY_TITLE]',
    // Example: 'Our Philosophy' or 'How We Work'
    items: [
      {
        title: '[PRINCIPLE_1_TITLE]',
        description: '[PRINCIPLE_1_FULL_DESCRIPTION]',
        icon: 'tabler:trophy',
      },
      {
        title: '[PRINCIPLE_2_TITLE]',
        description: '[PRINCIPLE_2_FULL_DESCRIPTION]',
        icon: 'tabler:target',
      },
      {
        title: '[PRINCIPLE_3_TITLE]',
        description: '[PRINCIPLE_3_FULL_DESCRIPTION]',
        icon: 'tabler:thumb-up',
      },
      {
        title: '[PRINCIPLE_4_TITLE]',
        description: '[PRINCIPLE_4_FULL_DESCRIPTION]',
        icon: 'tabler:sparkles',
      },
    ],
    image: {
      src: 'https://images.unsplash.com/photo-1620121692029-d088224ddc74?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Company philosophy visualization',
    },
  },

  // ========================================================================
  // 5. CORE SERVICES (3-Column Grid)
  // ========================================================================
  // Displayed as a 3-column grid with icons
  // Each service: title, description (2-3 sentences), icon
  services: {
    title: '[YOUR_SERVICES_TITLE]',
    // Example: 'Our Core Services' or 'What We Do'
    subtitle: '[YOUR_SERVICES_SUBTITLE]',
    // Example: 'We deliver results through expertise, innovation, and dedication.'
    items: [
      {
        title: '[SERVICE_1_NAME]',
        description: '[SERVICE_1_DESCRIPTION_2_3_SENTENCES]',
        icon: 'tabler:rocket',
      },
      {
        title: '[SERVICE_2_NAME]',
        description: '[SERVICE_2_DESCRIPTION_2_3_SENTENCES]',
        icon: 'tabler:brain',
      },
      {
        title: '[SERVICE_3_NAME]',
        description: '[SERVICE_3_DESCRIPTION_2_3_SENTENCES]',
        icon: 'tabler:shield-check',
      },
    ],
  },

  // ========================================================================
  // 6. WHY CHOOSE US (Steps/Process Section)
  // ========================================================================
  // Displayed as a horizontal process/timeline
  // Each item: title, description (1-2 sentences), icon
  whyUs: {
    title: 'Why [YOUR_SITE_NAME]?',
    subtitle: '[WHY_YOU_SUBTITLE]',
    // Example: 'The rules of the game have changed. Traditional approaches are fading; innovation is the future.'
    items: [
      {
        title: '[STEP_1_TITLE]',
        // Example: 'The Challenge'
        description: '[STEP_1_DESCRIPTION]',
        icon: 'tabler:alert-circle',
      },
      {
        title: '[STEP_2_TITLE]',
        // Example: 'Our Solution'
        description: '[STEP_2_DESCRIPTION]',
        icon: 'tabler:sun',
      },
      {
        title: '[STEP_3_TITLE]',
        // Example: 'The Outcome'
        description: '[STEP_3_DESCRIPTION]',
        icon: 'tabler:check',
      },
    ],
  },

  // ========================================================================
  // 7. CALL TO ACTION (Bottom Section)
  // ========================================================================
  cta: {
    title: '[CTA_MAIN_TITLE]',
    // Example: 'Ready to Get Started?' or 'Let\'s Work Together'
    subtitle: '[CTA_SUBTITLE_1_2_SENTENCES]',
    // Example: 'Contact us today to discuss how we can help you achieve your goals.'
    primaryAction: {
      text: '[CTA_PRIMARY_BUTTON_TEXT]',
      // Example: 'Contact Us' or 'Get Started'
      href: '/contact',
      icon: 'tabler:mail',
    },
    secondaryAction: {
      text: '[CTA_SECONDARY_BUTTON_TEXT]',
      // Example: 'View Our Work' or 'Learn More'
      href: '/services',
      icon: 'tabler:arrow-right',
    },
  },
};

// ========================================================================
// 🎨 LAYOUT COMPONENTS (Page Structure)
// ========================================================================
// The following code renders the page using the aboutData configuration above.
// No need to modify below unless you want to change the page structure.
// ========================================================================
---

<Layout metadata={aboutData.metadata}>
  <Hero tagline={aboutData.hero.tagline} image={aboutData.hero.image}>
    <Fragment slot="title" set:html={aboutData.hero.title} />
    <Fragment slot="subtitle" set:html={aboutData.hero.subtitle} />
  </Hero>

  <Features2
    title={aboutData.corePhilosophy.title}
    subtitle={aboutData.corePhilosophy.subtitle}
    columns={4}
    items={aboutData.corePhilosophy.items}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-slate-900"></div>
    </Fragment>
  </Features2>

  <Features3
    columns={2}
    title={aboutData.philosophyDetails.title}
    isAfterContent={true}
    items={aboutData.philosophyDetails.items}
    image={aboutData.philosophyDetails.image}
  />

  <Features2
    title={aboutData.services.title}
    subtitle={aboutData.services.subtitle}
    columns={3}
    items={aboutData.services.items}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <Steps2 title={aboutData.whyUs.title} subtitle={aboutData.whyUs.subtitle} items={aboutData.whyUs.items} />

  <CallToAction
    title={aboutData.cta.title}
    subtitle={aboutData.cta.subtitle}
    actions={[
      {
        variant: 'primary',
        text: aboutData.cta.primaryAction.text,
        href: aboutData.cta.primaryAction.href,
        icon: aboutData.cta.primaryAction.icon,
      },
      {
        text: aboutData.cta.secondaryAction.text,
        href: aboutData.cta.secondaryAction.href,
        icon: aboutData.cta.secondaryAction.icon,
      },
    ]}
  />
</Layout>
