---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Layout from '~/layouts/PageLayout.astro';

// -----------------------------------------------------------------------
// ⚙️ About Page Configuration (Edit content here)
// -----------------------------------------------------------------------

const aboutData = {
  // 1. Page Metadata
  metadata: {
    title: 'About [Your Site Name]',
  },

  // 2. Hero Section
  hero: {
    tagline: 'About [Your Site Name]',
    // Note: HTML tags like <br/> and <span> are supported here for styling
    title:
      'In the age of innovation, <br /> <span class="text-accent dark:text-white highlight"> Excellence Speaks</span>',
    subtitle:
      '[Your Site Name] is a forward-thinking company specializing in <strong>[Your Core Business Area]</strong> and <strong>[Your Secondary Focus]</strong>. We help our clients achieve their goals through innovation and expertise.',
    image: {
      src: 'https://images.unsplash.com/photo-1604871000636-074fa5117945?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Abstract geometric data structure',
    },
  },

  // 3. Core Philosophy (4 Grid Items)
  corePhilosophy: {
    title: 'Ready for the Future?',
    subtitle: 'Our core philosophy defines how we build for the future.',
    items: [
      { title: 'Innovation', description: 'First Priority', icon: 'tabler:robot' },
      { title: 'Quality', description: 'Our Focus', icon: 'tabler:target' },
      { title: 'Structure', description: 'Our Approach', icon: 'tabler:box-model-2' },
      { title: 'Excellence', description: 'Our Goal', icon: 'tabler:trophy' },
    ],
  },

  // 4. Philosophy Details (Split Layout)
  philosophyDetails: {
    title: 'Our Philosophy',
    items: [
      {
        title: 'Quality Over Quantity',
        description:
          'Delivering exceptional results matters more than doing more. We help you succeed through focused expertise.',
        icon: 'tabler:trophy',
      },
      {
        title: 'Precision Over Power',
        description:
          'Targeted solutions win over broad approaches. We focus on high-value, specific outcomes.',
        icon: 'tabler:target',
      },
      {
        title: 'Sustainable Growth',
        description: 'Build for the long term. Don\'t chase short-term trends at the expense of lasting value.',
        icon: 'tabler:thumb-up',
      },
      {
        title: 'Future-Ready',
        description: 'From traditional to modern. Build for tomorrow\'s challenges, not just today\'s needs.',
        icon: 'tabler:robot',
      },
    ],
    image: {
      src: 'https://images.unsplash.com/photo-1620121692029-d088224ddc74?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Structured data blocks',
    },
  },

  // 5. Core Services
  services: {
    title: 'Our Core Services',
    subtitle: 'We deliver results through expertise, innovation, and dedication to your success.',
    items: [
      {
        title: '[Service Area 1]',
        description:
          'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.',
        icon: 'tabler:seo',
      },
      {
        title: '[Service Area 2]',
        description:
          'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.',
        icon: 'tabler:api',
      },
      {
        title: '[Service Area 3]',
        description:
          'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.',
        icon: 'tabler:database',
      },
    ],
  },

  // 6. Why Choose Us (Steps)
  whyUs: {
    title: 'Why [Your Site Name]?',
    subtitle: 'The rules of the game have changed. Traditional approaches are fading; innovation is the future.',
    items: [
      {
        title: 'The Challenge',
        description:
          'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Traditional approaches no longer deliver results.',
        icon: 'tabler:alert-circle',
      },
      {
        title: 'Our Solution',
        description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. We create tailored solutions for your needs.',
        icon: 'tabler:adjustments',
      },
      {
        title: 'The Outcome',
        description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Your goals become reality.',
        icon: 'tabler:check',
      },
    ],
  },

  // 7. Call to Action (CTA)
  cta: {
    title: 'Ready to Get Started?',
    subtitle: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.',
    primaryAction: {
      text: 'Contact Us',
      href: '/contact',
      icon: 'tabler:mail',
    },
    secondaryAction: {
      text: 'Learn More',
      href: '/services',
      icon: 'tabler:brand-reddit',
    },
  },
};

// -----------------------------------------------------------------------
// 🧩 Layout Components (Page Structure - No need to edit below)
// -----------------------------------------------------------------------
---

<Layout metadata={aboutData.metadata}>
  <Hero tagline={aboutData.hero.tagline} image={aboutData.hero.image}>
    <Fragment slot="title" set:html={aboutData.hero.title} />
    <Fragment slot="subtitle" set:html={aboutData.hero.subtitle} />
  </Hero>

  <Features2
    title={aboutData.corePhilosophy.title}
    subtitle={aboutData.corePhilosophy.subtitle}
    columns={4}
    items={aboutData.corePhilosophy.items}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-slate-900"></div>
    </Fragment>
  </Features2>

  <Features3
    columns={2}
    title={aboutData.philosophyDetails.title}
    isAfterContent={true}
    items={aboutData.philosophyDetails.items}
    image={aboutData.philosophyDetails.image}
  />

  <Features2
    title={aboutData.services.title}
    subtitle={aboutData.services.subtitle}
    columns={3}
    items={aboutData.services.items}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <Steps2 title={aboutData.whyUs.title} subtitle={aboutData.whyUs.subtitle} items={aboutData.whyUs.items} />

  <CallToAction
    title={aboutData.cta.title}
    subtitle={aboutData.cta.subtitle}
    actions={[
      {
        variant: 'primary',
        text: aboutData.cta.primaryAction.text,
        href: aboutData.cta.primaryAction.href,
        icon: aboutData.cta.primaryAction.icon,
      },
      {
        text: aboutData.cta.secondaryAction.text,
        href: aboutData.cta.secondaryAction.href,
        icon: aboutData.cta.secondaryAction.icon,
      },
    ]}
  />
</Layout>
